{
	"name": "@inpyjamas/p5kit",
	"type": "module",
	"version": "1.3.0",
	"scripts": {
		"dev": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/netlify": "^7.0.0",
		"astro": "^5.18.0",
		"jszip": "^3.10.1",
		"tar": "^7.5.11",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@technologiestiftung/semantic-release-config": "1.2.4",
		"semantic-release": "24.2.9"
	},
	"prettier": {
		"tabWidth": 2,
		"semi": true,
		"singleQuote": false,
		"useTabs": true,
		"printWidth": 80,
		"overrides": [
			{
				"files": [
					"*.yml",
					"*.yaml"
